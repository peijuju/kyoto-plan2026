rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 256);
    }

    function isCollaborator(tripId) {
      return isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.collaborators
      );
    }

    function isValidTrip(data) {
      return data.userId == request.auth.uid &&
             data.collaborators is list &&
             data.userId in data.collaborators &&
             data.title is string && data.title.size() <= 256 && data.title.size() > 0 &&
             (data.get('dateRange', '') is string && data.get('dateRange', '').size() <= 100);
    }

    function isValidExpense(data, tripId) {
      return data.userId == request.auth.uid &&
             data.tripId == tripId &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 256 &&
             data.amount is number && data.amount >= 0 &&
             data.currency in ['JPY', 'TWD'] &&
             data.paymentMethod in ['cash', 'credit'] &&
             data.category in ['transport', 'food', 'hotel', 'ticket', 'shopping', 'other'];
    }

    // --- Patterns ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );
    }

    match /trips/{tripId} {
      allow list: if isSignedIn() && (resource.data.collaborators.hasAny([request.auth.uid]));
      allow get: if isSignedIn() && isValidId(tripId);
      allow create: if isSignedIn() && isValidId(tripId) && isValidTrip(incoming());
      allow update: if isSignedIn() && isValidId(tripId) && (
        existing().collaborators.hasAny([request.auth.uid])
      ) && isValidTrip(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'dateRange', 'data', 'updatedAt', 'collaborators'])
      );
      allow delete: if isSignedIn() && isValidId(tripId) && existing().userId == request.auth.uid;

      match /expenses/{expenseId} {
        allow list: if isSignedIn() && 
                      get(/databases/$(database)/documents/trips/$(tripId)).data.collaborators.hasAny([request.auth.uid]);
        allow get: if isSignedIn() && isValidId(expenseId) &&
                      get(/databases/$(database)/documents/trips/$(tripId)).data.collaborators.hasAny([request.auth.uid]);
        allow create: if isSignedIn() && isValidId(expenseId) &&
                         get(/databases/$(database)/documents/trips/$(tripId)).data.collaborators.hasAny([request.auth.uid]) &&
                         isValidExpense(incoming(), tripId);
        allow update: if isSignedIn() && isValidId(expenseId) &&
                         get(/databases/$(database)/documents/trips/$(tripId)).data.collaborators.hasAny([request.auth.uid]) &&
                         isValidExpense(incoming(), tripId) &&
                         (
                           incoming().diff(existing()).affectedKeys().hasOnly(['name', 'date', 'amount', 'currency', 'paymentMethod', 'category', 'notes'])
                         );
        allow delete: if isSignedIn() && isValidId(expenseId) &&
                         get(/databases/$(database)/documents/trips/$(tripId)).data.collaborators.hasAny([request.auth.uid]);
      }
    }
  }
}
